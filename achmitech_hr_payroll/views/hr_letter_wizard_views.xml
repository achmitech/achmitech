    <record id="action_open_wizard_amenagement_stage_from_employee" model="ir.actions.act_window">
        <field name="name">Aménagement Stage</field>
        <field name="res_model">hr.letter.wizard</field>
        <field name="view_id" ref="hr_letter_wizard_amenagement_stage_view"/>
        <field name="view_mode">form</field>
