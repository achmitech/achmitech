<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add N° Rubrique field to salary rule form, next to the code field -->
    <record id="view_hr_salary_rule_form_rubric" model="ir.ui.view">
        <field name="name">hr.salary.rule.form.rubric</field>
        <field name="model">hr.salary.rule</field>
        <field name="inherit_id" ref="hr_payroll.hr_salary_rule_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="l10n_ma_rubric_number" string="N° Rubrique"/>
            </xpath>
        </field>
    </record>

</odoo>