    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout">
                <t t-call="achmitech_hr_payroll.report_hr_letters_assets"/>
                <t t-call="achmitech_hr_payroll.report_certificat_travail_document"/>
            </t>
        </t>
    </t>
</template>

