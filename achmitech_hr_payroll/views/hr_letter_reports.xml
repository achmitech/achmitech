<!-- ================================================================
     5. CERTIFICAT DE TRAVAIL
         doc = hr.letter.wizard
     ================================================================ -->
<template id="report_certificat_travail_document">
    <t t-set="employee"  t-value="doc.employee_id"/>
    <t t-set="company"   t-value="employee.company_id"/>
    <t t-set="civility"  t-value="'Madame' if employee.sex == 'female' else 'Monsieur'"/>
    <t t-set="versions"  t-value="env['hr.version'].search([('employee_id', '=', employee.id)], order='contract_date_start asc')"/>

    <div class="page">

        <!-- Title -->
        <h2 style="text-align: center; font-variant: small-caps; font-size: 18pt; margin-bottom: 50pt;">
            <t t-if="employee.departure_date">Certificat de Travail</t>
            <t t-else="">Attestation de Travail</t>
        </h2>
        <br/><br/><br/><br/>
        <!-- Body — single position -->
        <t t-if="len(versions) &lt;= 1">
            <t t-set="v" t-value="versions[0] if versions else employee.version_id"/>
            <p style="font-size: 12pt; line-height: 2.4; text-align: justify;">
                Je soussigné Mr <span class="bold">Aziz ACHMIT</span>,
                Gérant de la société <span class="bold"><t t-out="company.name or 'ACHMITECH SARL'"/></span>,
                certifie par la présente que
                <span class="bold"><t t-out="civility"/> <t t-out="employee.name or ''"/></span>,
                titulaire de la Carte d'Identité Nationale N°&#160;<span class="bold"><t t-out="employee.l10n_ma_cin_number or '__________'"/></span>,
                <t t-if="employee.departure_date">
                    a occupé le poste de
                    <span class="bold"><t t-out="v.job_id.name or '__________________'"/></span>
                    au sein de notre société du
                    <span class="bold"><t t-out="v.contract_date_start.strftime('%d/%m/%Y') if v.contract_date_start else '__/__/____'"/></span>
                    au <span class="bold"><t t-out="employee.departure_date.strftime('%d/%m/%Y')"/></span>.
                </t>
                <t t-else="">
                    occupe le poste de
                    <span class="bold"><t t-out="v.job_id.name or '__________________'"/></span>
                    au sein de notre société depuis le
                    <span class="bold"><t t-out="v.contract_date_start.strftime('%d/%m/%Y') if v.contract_date_start else '__/__/____'"/></span>,
                    et ce <span class="bold">à ce jour</span>.
                </t>
            </p>
        </t>

        <!-- Body — multiple positions -->
        <t t-else="">
            <p style="font-size: 12pt; line-height: 2.0; text-align: justify;">
                Je soussigné Mr <span class="bold">Aziz ACHMIT</span>,
                Gérant de la société <span class="bold"><t t-out="company.name or 'ACHMITECH SARL'"/></span>,
                certifie par la présente que
                <span class="bold"><t t-out="civility"/> <t t-out="employee.name or ''"/></span>,
                titulaire de la Carte d'Identité Nationale N°&#160;<span class="bold"><t t-out="employee.l10n_ma_cin_number or '__________'"/></span>,
                a successivement occupé les postes suivants au sein de notre société :
            </p>
            <ul style="font-size: 12pt; line-height: 2.0; margin: 10pt 0 10pt 20pt;">
                <t t-foreach="versions" t-as="v">
                    <li>
                        <span class="bold"><t t-out="v.job_id.name or '__________________'"/></span>
                        — du <span class="bold"><t t-out="v.contract_date_start.strftime('%d/%m/%Y') if v.contract_date_start else '__/__/____'"/></span>
                        au <span class="bold">
                            <t t-if="v_last and employee.departure_date">
                                <t t-out="employee.departure_date.strftime('%d/%m/%Y')"/>
                            </t>
                            <t t-elif="v_last">
                                à ce jour
                            </t>
                            <t t-else="">
                                <t t-out="v.contract_date_end.strftime('%d/%m/%Y') if v.contract_date_end else '__/__/____'"/>
                            </t>
                        </span>
                    </li>
                </t>
            </ul>
        </t>
        <br/>
        <p style="font-size: 12pt;">
            La présente attestation lui est délivrée à sa demande pour servir et valoir ce que de droit.
        </p>
        <br/><br/><br/><br/><br/><br/><br/>

        <!-- Fait à + signature bloc -->
        <table style="width:100%; border-collapse:collapse; margin-top: 10pt;">
            <tr>
                <td style="width:50%; vertical-align:top; border:1px solid #fff;">
                    <p style="font-size:12pt;">
                        Fait à <span class="bold"><t t-out="company.city or 'Rabat'"/></span>,
                        le <span class="bold"><t t-out="datetime.date.today().strftime('%d/%m/%Y')"/></span>
                    </p>
                </td>
            </tr>
            <tr>
                <td style="width:50%; vertical-align:top; border:1px solid #fff;">
                    <p class="bold underline" style="font-size:12pt;">La Société :</p>
                    <br/><br/><br/><br/><br/>
                    <p style="font-size:12pt;">_______________</p>
                    <p style="font-size:12pt;">Aziz ACHMIT</p>
                    <p style="font-size:12pt;">Gérant</p>
                </td>
            </tr>
        </table>

    </div>
</template>

