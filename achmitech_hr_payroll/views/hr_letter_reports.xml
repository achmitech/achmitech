    <field name="model">hr.letter.wizard</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">achmitech_hr_payroll.report_amenagement_stage</field>
    <field name="report_file">achmitech_hr_payroll.report_amenagement_stage</field>
