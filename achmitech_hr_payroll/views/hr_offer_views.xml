<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_contract_salary_offer_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.contract.salary.offer.view.form.inherit.achmitech</field>
        <field name="model">hr.contract.salary.offer</field>
        <field name="inherit_id" ref="hr_contract_salary.hr_contract_salary_offer_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_jump_to_offer']" position="after">
                <button
                    name="action_preview_offer_documents"
                    type="object"
                    string="Aperçu documents"
                    class="btn btn-secondary"
                    invisible="not id or not contract_template_id"/>
            </xpath>
            <xpath expr="//group[@name='group_offer']" position="inside">
                <field name="client_id" options="{'no_create': True}" readonly="state in ['half_signed', 'full_signed']"/>
                <field name="mission_order_ref" readonly="state in ['half_signed', 'full_signed']"/>
            </xpath>
            <xpath expr="//group[@name='salary_simulation_group']" position="after">
                <group string="Indemnités" name="group_indemnities">
                    <field name="l10n_ma_meal_allowance"/>
                    <field name="l10n_ma_transport_exemption"/>
                    <field name="l10n_ma_kilometric_exemption"/>
                    <field name="l10n_ma_phone_allowance"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Hide benefits section (left) and salary summary sidebar (right) from employee portal -->
    <template id="salary_package_benefits_hide" inherit_id="hr_contract_salary.salary_package_benefits">
        <xpath expr="//div[@id='hr_cs_configurator']" position="attributes">
            <attribute name="style">visibility:hidden; height:0; overflow:hidden; margin:0; padding:0;</attribute>
        </xpath>
    </template>

    <!-- Hide only the resume summary block, keep the sign/feedback buttons -->
    <template id="salary_package_sidebar_hide" inherit_id="hr_contract_salary.salary_package_sidebar">
        <xpath expr="//div[@name='salary_package_resume']" position="attributes">
            <attribute name="style">display:none;</attribute>
        </xpath>
    </template>

    <!-- Change misleading page title on employee contract portal -->
    <template id="salary_package_title_hide" inherit_id="hr_contract_salary.salary_package">
        <xpath expr="//h1[1]" position="replace">
            <h1>Votre contrat de travail</h1>
        </xpath>
    </template>

</odoo>
