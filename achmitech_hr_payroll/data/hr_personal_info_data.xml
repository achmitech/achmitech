<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Morocco IDs — CIN already added by l10n_ma_hr_payroll, only CNSS added here -->
        <record id="hr_contract_salary_personal_info_cnss" model="hr.contract.salary.personal.info">
            <field name="name">CNSS Number</field>
            <field name="res_field_id" model="ir.model.fields" eval="obj().search([('model', '=', 'hr.employee'), ('name', '=', 'l10n_ma_cnss_number')])"/>
            <field name="info_type_id" ref="hr_contract_salary.hr_contract_salary_personal_info_type_general"/>
            <field name="applies_on">employee</field>
            <field name="is_required">False</field>
            <field name="sequence">46</field>
        </record>
    </data>
</odoo>
