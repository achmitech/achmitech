<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_salary_simulator_view_form" model="ir.ui.view">
        <field name="name">hr.salary.simulator.view.form</field>
        <field name="model">hr.salary.simulator</field>
        <field name="arch" type="xml">
            <form string="Simulateur de salaire">
                <field name="currency_id" invisible="1"/>
                <field name="wage_type" invisible="1"/>

                <div class="row">

                    <!-- Left: inputs -->
                    <div class="col-md-6">
                        <div class="alert alert-warning" role="alert"
                             invisible="not no_config_warning">
                            Aucune configuration de simulation pour cette structure.
                            Les lignes de la fiche de paie seront affichées brutes.
                        </div>
                        <field name="no_config_warning" invisible="1"/>
                        <group>
                            <field name="structure_id" options="{'no_open': True, 'no_create': True}" required="1"/>
                            <field name="resource_calendar_id" placeholder="Horaire de la société" options="{'no_open': True, 'no_create': True}" readonly="1"/>
                            <field name="monthly_wage" invisible="wage_type == 'hourly'"/>
                            <field name="hourly_wage" invisible="wage_type != 'hourly'"/>
                            <field name="target_net_wage" string="Net souhaité (ou laisser vide)"
                                   invisible="wage_type == 'hourly'"/>
                        </group>
                        <div invisible="not benefit_line_ids">
                            <separator string="Indemnités"/>
                            <field name="benefit_line_ids" nolabel="1">
                                <list editable="bottom" no_open="1" create="0" default_order="name">
                                    <field name="name" readonly="1" force_save="1"/>
                                    <field name="field_name" column_invisible="1"/>
                                    <field name="value" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </div>
                    </div>

                    <!-- Right: results -->
                    <div class="col-md-6" invisible="not result_line_ids">
                        <group>
                            <field name="gross_wage" widget="monetary" readonly="1"
                                   options="{'currency_field': 'currency_id'}"
                                   string="Brut"/>
                            <field name="net_wage" widget="monetary" readonly="1"
                                   options="{'currency_field': 'currency_id'}"
                                   string="Net"/>
                        </group>
                        <field name="result_line_ids" nolabel="1" options="{'no_create': True}">
                            <list no_open="1" create="0">
                                <field name="name" readonly="1"/>
                                <field name="total" widget="monetary" readonly="1" options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" column_invisible="1"/>
                            </list>
                        </field>
                    </div>

                </div>

                <footer>
                    <button name="action_simulate" type="object" string="Simuler" class="btn-primary"/>
                    <button special="cancel" string="Fermer" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_salary_simulator" model="ir.actions.act_window">
        <field name="name">Simulateur de salaire</field>
        <field name="res_model">hr.salary.simulator</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="hr_salary_simulator_view_form"/>
    </record>

    <menuitem
        id="menu_hr_salary_simulator"
        name="Simulateur de salaire"
        action="action_hr_salary_simulator"
        parent="hr_payroll.menu_hr_payroll_employees"
        sequence="41"
        groups="hr_payroll.group_hr_payroll_user"/>

</odoo>
