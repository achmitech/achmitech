<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_staffing_transfer_wizard_form" model="ir.ui.view">
    <field name="name">staffing.transfer.wizard.form</field>
    <field name="model">staffing.transfer.wizard</field>
    <field name="arch" type="xml">
      <form string="Transférer les besoins restants">
        <sheet>
          <group>
            <field name="source_plan_id" readonly="1"/>
            <field name="source_company_id" invisible="1"/>
            <field name="target_plan_id" required="1"/>
          </group>
          <field name="line_ids" nolabel="1">
            <list create="0" edit="0">
              <field name="selected"/>
              <field name="name" string="Poste"/>
              <field name="partner_id" string="Client"/>
              <field name="number_of_positions"/>
              <field name="positions_filled"/>
              <field name="remaining_positions"
                     decoration-warning="remaining_positions == 0"/>
            </list>
          </field>
        </sheet>
        <footer>
          <button name="action_confirm" type="object" string="Transférer" class="btn-primary"/>
          <button string="Annuler" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

</odoo>
